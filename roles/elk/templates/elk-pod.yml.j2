---
apiVersion: v1
kind: ConfigMap
metadata:
  name: elk-elasticsearch
  labels:
    app: elk
data:
  elasticsearch.yml: |
{{ elk_cm_elasticsearch.content | b64decode | indent(4) }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: elk-logstash-config
  labels:
    app: elk
data:
  logstash.yml: |
{{ elk_cm_logstash_config.content | b64decode | indent(4) }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: elk-logstash-pipeline
  labels:
    app: elk
data:
  pipeline.conf: |
{{ elk_cm_logstash_pipeline.content | b64decode | indent(4) }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: elk-kibana
  labels:
    app: elk
data:
  kibana.yml: |
{{ elk_cm_kibana.content | b64decode | indent(4) }}
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: {{ elk_pod_name }}-elasticsearch-data
  labels:
    app: elk
spec:
  capacity:
    storage: 50Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  hostPath:
    path: {{ elasticsearch_data_dir }}
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ elk_pod_name }}-elasticsearch-data
  labels:
    app: elk
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 50Gi
---
apiVersion: v1
kind: Pod
metadata:
  name: {{ elk_pod_name }}
  labels:
    app: elk
spec:
  containers:
    - name: elasticsearch
      image: {{ elk_elasticsearch_image }}
      ports:
        - containerPort: {{ elasticsearch_http_port }}
          hostIP: 127.0.0.1
          hostPort: {{ elasticsearch_http_port }}
        - containerPort: {{ elasticsearch_transport_port }}
          hostIP: 127.0.0.1
          hostPort: {{ elasticsearch_transport_port }}
      env:
        - name: discovery.type
          value: single-node
        - name: ES_JAVA_OPTS
          value: "-Xms{{ elasticsearch_heap_size }} -Xmx{{ elasticsearch_heap_size }}"
        - name: xpack.security.enabled
          value: "false"
        - name: xpack.security.enrollment.enabled
          value: "false"
        - name: ingest.geoip.downloader.enabled
          value: "false"
      volumeMounts:
        - name: elasticsearch-data
          mountPath: /usr/share/elasticsearch/data
        - name: elasticsearch-config
          mountPath: /usr/share/elasticsearch/config/elasticsearch.yml
          subPath: elasticsearch.yml
      resources:
        limits:
          memory: 5Gi
        requests:
          memory: 4Gi
      livenessProbe:
        httpGet:
          path: /_cluster/health
          port: {{ elasticsearch_http_port }}
        initialDelaySeconds: 60
        periodSeconds: 30
        timeoutSeconds: 10
        failureThreshold: 10

    - name: logstash
      image: {{ elk_logstash_image }}
      ports:
        - containerPort: {{ logstash_beats_port }}
          hostIP: 127.0.0.1
          hostPort: {{ logstash_beats_port }}
        - containerPort: {{ logstash_http_port }}
          hostIP: 127.0.0.1
          hostPort: {{ logstash_http_port }}
      env:
        - name: LS_JAVA_OPTS
          value: "-Xms{{ logstash_heap_size }} -Xmx{{ logstash_heap_size }}"
      volumeMounts:
        - name: logstash-config
          mountPath: /usr/share/logstash/config/logstash.yml
          subPath: logstash.yml
        - name: logstash-pipeline
          mountPath: /usr/share/logstash/pipeline/pipeline.conf
          subPath: pipeline.conf
      resources:
        limits:
          memory: 3Gi
        requests:
          memory: 2Gi
      livenessProbe:
        httpGet:
          path: /
          port: {{ logstash_http_port }}
        initialDelaySeconds: 60
        periodSeconds: 30
        timeoutSeconds: 10
        failureThreshold: 3

    - name: kibana
      image: {{ elk_kibana_image }}
      ports:
        - containerPort: {{ kibana_port }}
          hostIP: 127.0.0.1
          hostPort: {{ kibana_port }}
      env:
        - name: ELASTICSEARCH_HOSTS
          value: "http://elasticsearch:{{ elasticsearch_http_port }}"
        - name: XPACK_SECURITY_ENABLED
          value: "false"
      volumeMounts:
        - name: kibana-config
          mountPath: /usr/share/kibana/config/kibana.yml
          subPath: kibana.yml
      resources:
        limits:
          memory: 1Gi
        requests:
          memory: 512Mi
      livenessProbe:
        httpGet:
          path: /api/status
          port: {{ kibana_port }}
        initialDelaySeconds: 120
        periodSeconds: 30
        timeoutSeconds: 10
        failureThreshold: 10

  volumes:
    - name: elasticsearch-data
      persistentVolumeClaim:
        claimName: {{ elk_pod_name }}-elasticsearch-data
    - name: elasticsearch-config
      configMap:
        name: elk-elasticsearch
    - name: logstash-config
      configMap:
        name: elk-logstash-config
    - name: logstash-pipeline
      configMap:
        name: elk-logstash-pipeline
    - name: kibana-config
      configMap:
        name: elk-kibana
