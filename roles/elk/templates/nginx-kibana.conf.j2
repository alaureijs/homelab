server {
    listen 443 ssl;
    http2 on;
    server_name observability.local.lan;

    ssl_certificate {{ elk_nginx_cert_path }};
    ssl_certificate_key {{ elk_nginx_key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Kibana
    location /kibana/ {
        proxy_pass http://127.0.0.1:{{ kibana_port }}/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Elasticsearch (read-only, for debugging)
    location /elasticsearch/ {
        proxy_pass http://127.0.0.1:{{ elasticsearch_http_port }}/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    server_name observability.local.lan;
    return 308 https://$host$request_uri;
}
