# Managed by Ansible
# Harbor configuration file

hostname: {{ harbor_hostname }}

http:
  port: {{ harbor_http_port }}

{% if harbor_tls_enabled %}
https:
  port: {{ harbor_https_port }}
  certificate: {{ harbor_tls_cert_path }}
  key: {{ harbor_tls_key_path }}
{% else %}
# https:
#   port: 443
#   certificate: /your/certificate/path
#   key: /your/key/path
{% endif %}

# Uncomment external_url if you enabled notary or trivy
# external_url: https://reg.yourdomain.com

harbor_admin_password: {{ harbor_admin_password }}

database:
  password: {{ harbor_database_password }}
  max_idle_conns: 100
  max_open_conns: 900
  conn_max_lifetime: 5m
  conn_max_idle_time: 0
  sslmode: disable
  password: {{ harbor_database_password }}

data_volume: {{ harbor_data_dir }}

storage_service:
  filesystem:
    maxthreads: 100

redis:
  password: {{ harbor_redis_password }}

jobservice:
  max_job_workers: 10
  job_loggers:
    - STD_OUTPUT
    - FILE
  logger_sweeper_duration: 1 #days

log:
  level: info
  local:
    rotate_count: 50
    rotate_size: 200M
    location: /var/log/harbor
