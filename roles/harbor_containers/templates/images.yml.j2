---
# Auto-generated by sync-update-containers playbook
# Last sync: {{ ansible_date_time.iso8601 }}
#
# Update inventory/group_vars/all/main.yml with these versions,
# then run: ansible-playbook playbooks/sync-update-containers.yml

{% for image in harbor_sync_images %}
{% set short_name = image.name | regex_replace('.*/', '') %}
{% set var_name = short_name | regex_replace('-', '_') + '_version' %}
{% set latest = harbor_containers_sync_report[short_name]['latest_version'] | default(harbor_containers_sync_report[short_name]['current_tag']) %}
{{ var_name }}: "{{ latest }}"
{% endfor %}
