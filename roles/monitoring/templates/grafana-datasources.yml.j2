apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: https://{{ monitoring_hostname }}/prometheus/
    isDefault: true
    editable: false

  - name: Alertmanager
    type: alertmanager
    access: proxy
    url: https://{{ monitoring_hostname }}:9093
    editable: false
    jsonData:
      implementation: prometheus
