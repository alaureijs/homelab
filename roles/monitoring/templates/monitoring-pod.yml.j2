---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: {{ monitoring_pod_name }}-grafana-data
  labels:
    app: monitoring
spec:
  capacity:
    storage: 5Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  hostPath:
    path: {{ monitoring_data_dir }}/grafana
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ monitoring_pod_name }}-grafana-data
  labels:
    app: monitoring
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 5Gi
---
