apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ monitoring_pod_name }}-datasources
  labels:
    app: monitoring
data:
  datasources.yml: |
    apiVersion: 1
    datasources:
      - name: Prometheus
        type: prometheus
        access: proxy
        url: https://{{ monitoring_hostname }}/prometheus/
        isDefault: true
        editable: false
      - name: Alertmanager
        type: alertmanager
        access: proxy
        url: https://{{ monitoring_hostname }}:9093
        editable: false
        jsonData:
          implementation: prometheus
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ monitoring_pod_name }}-dashboards-provider
  labels:
    app: monitoring
data:
  dashboards.yml: |
    apiVersion: 1
    providers:
      - name: 'default'
        orgId: 1
        folder: ''
        type: file
        disableDeletion: false
        editable: true
        updateIntervalSeconds: 30
        options:
          path: /var/lib/grafana/dashboards
          foldersFromFilesStructure: false
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ monitoring_pod_name }}-prometheus
  labels:
    app: monitoring
data:
  prometheus.yml: |
    global:
      scrape_interval: {{ monitoring_prometheus_scrape_interval }}
      evaluation_interval: {{ monitoring_prometheus_evaluation_interval }}

      external_labels:
        cluster: local
        environment: lab

    rule_files:
      - /etc/prometheus/rules/*.yml

    alerting:
      alertmanagers:
        - static_configs:
            - targets:
                - localhost:9093

    scrape_configs:
      - job_name: prometheus
        metrics_path: /prometheus/metrics
        static_configs:
          - targets:
              - localhost:9090

      - job_name: node-exporter
        scheme: https
        tls_config:
          ca_file: {{ monitoring_mtls_ca_cert }}
          cert_file: {{ monitoring_mtls_client_cert }}
          key_file: {{ monitoring_mtls_client_key }}
        static_configs:
          - targets:
{% for host in groups['all'] | sort %}
{% if hostvars[host].get('node_exporter_enabled', true) %}
              - "{{ hostvars[host]['vm_hostname'] }}.{{ lab_domain }}:{{ hostvars[host].get('node_exporter_port', 9100) }}"
{% endif %}
{% endfor %}
            labels:
              cluster: local

      - job_name: alertmanager
        static_configs:
          - targets:
              - localhost:9093
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ monitoring_pod_name }}-prometheus-rules
  labels:
    app: monitoring
data:
  node-exporter.yml: |
    groups:
      - name: node-exporter
        rules:
          - alert: HighCPUUsage
            expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 80
            for: 5m
            labels:
              severity: warning
            annotations:
              summary: "High CPU usage on {{ $labels.instance }}"
              description: "CPU usage is above 80% for more than 5 minutes"

          - alert: HighMemoryUsage
            expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100 > 80
            for: 5m
            labels:
              severity: warning
            annotations:
              summary: "High memory usage on {{ $labels.instance }}"
              description: "Memory usage is above 80% for more than 5 minutes"

          - alert: HighDiskUsage
            expr: (1 - (node_filesystem_avail_bytes{fstype!="tmpfs"} / node_filesystem_size_bytes{fstype!="tmpfs"})) * 100 > 85
            for: 5m
            labels:
              severity: warning
            annotations:
              summary: "High disk usage on {{ $labels.instance }}"
              description: "Disk usage is above 85% for more than 5 minutes"

          - alert: NodeDown
            expr: up{job="node-exporter"} == 0
            for: 1m
            labels:
              severity: critical
            annotations:
              summary: "Node {{ $labels.instance }} is down"
              description: "Node has been unreachable for more than 1 minute"
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ monitoring_pod_name }}-alertmanager
  labels:
    app: monitoring
data:
  alertmanager.yml: |
    global:
{% if monitoring_alertmanager_smtp_smarthost %}
      smtp_smarthost: "{{ monitoring_alertmanager_smtp_smarthost }}"
      smtp_from: "{{ monitoring_alertmanager_smtp_from }}"
      smtp_auth_username: "{{ monitoring_alertmanager_smtp_auth_username }}"
      smtp_auth_password: "{{ monitoring_alertmanager_smtp_auth_password }}"
{% endif %}

    route:
      group_by: ['alertname']
      group_wait: 10s
      group_interval: 10s
      repeat_interval: 1h
      receiver: default

    receivers:
      - name: default

    inhibit_rules:
      - source_match:
          severity: critical
        target_match:
          severity: warning
        equal: ['alertname', 'dev', 'instance']
---
apiVersion: v1
kind: Pod
metadata:
  name: {{ monitoring_pod_name }}
  labels:
    app: monitoring
spec:
  containers:
    - name: grafana
      image: {{ monitoring_grafana_image }}
      ports:
        - containerPort: 3000
          hostPort: 3000
          hostIP: "127.0.0.1"
      env:
        - name: GF_SERVER_ROOT_URL
          value: "https://{{ monitoring_hostname }}/grafana/"
        - name: GF_SERVER_SERVE_FROM_SUB_PATH
          value: "true"
        - name: GF_SECURITY_ADMIN_PASSWORD
          value: "{{ monitoring_grafana_admin_password }}"
        - name: GF_USERS_ALLOW_SIGN_UP
          value: "false"
      volumeMounts:
        - name: grafana-data
          mountPath: /var/lib/grafana
        - name: grafana-datasources
          mountPath: /etc/grafana/provisioning/datasources/datasources.yml
          subPath: datasources.yml
        - name: grafana-dashboards-provider
          mountPath: /etc/grafana/provisioning/dashboards/dashboards.yml
          subPath: dashboards.yml
{% for dashboard in monitoring_grafana_dashboards %}
        - name: grafana-dashboard-{{ dashboard.name }}
          mountPath: /var/lib/grafana/dashboards/{{ dashboard.name }}.json
          subPath: {{ dashboard.name }}.json
{% endfor %}
      resources:
        limits:
          memory: 512M
        requests:
          memory: 256M

    - name: prometheus
      image: {{ monitoring_prometheus_image }}
      args:
        - "--config.file=/etc/prometheus/prometheus.yml"
        - "--storage.tsdb.path=/prometheus"
        - "--storage.tsdb.retention.time={{ monitoring_prometheus_retention }}"
        - "--storage.tsdb.retention.size={{ monitoring_prometheus_retention_size }}"
        - "--web.enable-lifecycle"
        - "--web.external-url=https://{{ monitoring_hostname }}/prometheus/"
        - "--web.route-prefix=/prometheus/"
      ports:
        - containerPort: 9090
          hostPort: 9090
          hostIP: "127.0.0.1"
      volumeMounts:
        - name: prometheus-data
          mountPath: /prometheus
        - name: prometheus-config
          mountPath: /etc/prometheus/prometheus.yml
          subPath: prometheus.yml
        - name: prometheus-rules
          mountPath: /etc/prometheus/rules
        - name: prometheus-mtls
          mountPath: /etc/prometheus/mtls
      resources:
        limits:
          memory: 1G
        requests:
          memory: 512M

    - name: alertmanager
      image: {{ monitoring_alertmanager_image }}
      args:
        - "--config.file=/etc/alertmanager/alertmanager.yml"
        - "--storage.path=/alertmanager"
      ports:
        - containerPort: 9093
          hostPort: 9093
          hostIP: "127.0.0.1"
      volumeMounts:
        - name: alertmanager-data
          mountPath: /alertmanager
        - name: alertmanager-config
          mountPath: /etc/alertmanager/alertmanager.yml
          subPath: alertmanager.yml
      resources:
        limits:
          memory: 256M
        requests:
          memory: 128M

  volumes:
    - name: grafana-data
      hostPath:
        path: {{ monitoring_data_dir }}/grafana
        type: DirectoryOrCreate
    - name: grafana-datasources
      configMap:
        name: {{ monitoring_pod_name }}-datasources
    - name: grafana-dashboards-provider
      configMap:
        name: {{ monitoring_pod_name }}-dashboards-provider
{% for dashboard in monitoring_grafana_dashboards %}
    - name: grafana-dashboard-{{ dashboard.name }}
      configMap:
        name: {{ monitoring_pod_name }}-dashboard-{{ dashboard.name }}
{% endfor %}
    - name: prometheus-data
      hostPath:
        path: {{ monitoring_data_dir }}/prometheus
        type: DirectoryOrCreate
    - name: prometheus-config
      configMap:
        name: {{ monitoring_pod_name }}-prometheus
    - name: prometheus-rules
      configMap:
        name: {{ monitoring_pod_name }}-prometheus-rules
    - name: prometheus-mtls
      hostPath:
        path: {{ monitoring_mtls_dir }}
        type: Directory
    - name: alertmanager-data
      hostPath:
        path: {{ monitoring_data_dir }}/alertmanager
        type: DirectoryOrCreate
    - name: alertmanager-config
      configMap:
        name: {{ monitoring_pod_name }}-alertmanager
