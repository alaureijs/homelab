global:
  scrape_interval: {{ monitoring_prometheus_scrape_interval }}
  evaluation_interval: {{ monitoring_prometheus_evaluation_interval }}

  external_labels:
    cluster: local
    environment: lab

rule_files:
  - /etc/prometheus/rules/*.yml

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - localhost:9093

scrape_configs:
  - job_name: prometheus
    metrics_path: /prometheus/metrics
    static_configs:
      - targets:
          - localhost:9090

{% include 'prometheus-node-exporter.yml.j2' %}

  - job_name: alertmanager
    static_configs:
      - targets:
          - localhost:9093

  - job_name: harbor
    scheme: http
    tls_config:
      insecure_skip_verify: true
    basic_auth:
      username: metrics
      password: {{ vault_harbor_metrics_password }}
    metrics_path: /metrics
    static_configs:
      - targets:
          - {{ harbor_hostname }}:{{ harbor_metrics_port }}
        labels:
          cluster: local

  - job_name: elasticsearch
    static_configs:
      - targets:
          - ansible03.{{ lab_domain }}:{{ elk_elasticsearch_exporter_port }}
        labels:
          cluster: local
